<?xml version="1.0" encoding="utf-8"?>
<!-- box_bg.xml — replicates .box from the PHP stylesheet:
     white background, 1px #ccc border, 4dp radius. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/retro_box_bg" />
    <stroke android:width="1dp" android:color="@color/retro_border" />
    <corners android:radius="4dp" />
</shape>
