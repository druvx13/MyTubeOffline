<?xml version="1.0" encoding="utf-8"?>
<!-- btn_classic.xml — replicates .btn-classic from the PHP stylesheet:
     #ddd background, #666 border, 3dp corner radius, 1dp border. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/retro_header" />
            <stroke android:width="1dp" android:color="@color/retro_button_border" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/retro_button_bg" />
            <stroke android:width="1dp" android:color="@color/retro_button_border" />
            <corners android:radius="3dp" />
        </shape>
    </item>
</selector>
