<?xml version="1.0" encoding="utf-8"?>
<!-- item_video.xml — one card in the home/account lists.
     Matches the .box style from the PHP: white bg, 1px #ccc border, 4dp radius. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/box_bg"
    android:layout_marginBottom="6dp"
    android:padding="6dp">

    <!-- 16:9-ish thumbnail -->
    <ImageView
        android:id="@+id/thumb"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:scaleType="centerCrop"
        android:background="@android:color/black"
        android:contentDescription="@string/thumbnail" />

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/retro_text"
        android:maxLines="2"
        android:ellipsize="end" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">

        <TextView
            android:id="@+id/views"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/retro_text_dim"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="·"
            android:textColor="@color/retro_text_dim"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="@color/retro_text_dim"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/uploader"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/retro_link"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <Button
            android:id="@+id/btn_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:background="@drawable/btn_classic"
            android:padding="6dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:textSize="12sp"
            android:text="@string/delete" />
    </LinearLayout>
</LinearLayout>
